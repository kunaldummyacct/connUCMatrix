<!DOCTYPE html>
<html>
<head>
    <title>Login - Connector Use Case Matrix</title>
    <style>
        body { font-family: Arial; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .login-box { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); width: 350px; }
        h2 { margin-top: 0; color: #333; text-align: center; }
        .login-type { display: flex; gap: 10px; margin: 20px 0; }
        .type-btn { flex: 1; padding: 15px; border: 2px solid #ddd; border-radius: 8px; background: white; cursor: pointer; text-align: center; transition: all 0.3s; }
        .type-btn:hover { border-color: #667eea; background: #f8f9ff; }
        .type-btn.active { border-color: #667eea; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
        .type-btn h3 { margin: 0 0 5px 0; font-size: 18px; }
        .type-btn p { margin: 0; font-size: 12px; opacity: 0.8; }
        #passwordField { display: none; }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 14px; }
        button[type="submit"] { width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px; font-weight: bold; margin-top: 10px; }
        button[type="submit"]:hover { opacity: 0.9; }
        button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }
        .error { color: #e74c3c; font-size: 14px; text-align: center; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>Connector Use Case Matrix</h2>
        {% if error %}
        <p class="error">{{ error }}</p>
        {% endif %}
        <form method="POST" id="loginForm">
            <div class="login-type">
                <div class="type-btn" onclick="selectType('guest')">
                    <h3>👤 Guest</h3>
                    <p>Read-only access</p>
                </div>
                <div class="type-btn" onclick="selectType('admin')">
                    <h3>🔐 Admin</h3>
                    <p>Full access</p>
                </div>
            </div>
            <input type="hidden" name="login_type" id="loginType" value="">
            <div id="passwordField">
                <input type="password" name="password" placeholder="Admin Password">
            </div>
            <button type="submit" id="submitBtn" disabled>Continue</button>
        </form>
    </div>
    <script>
        function selectType(type) {
            document.querySelectorAll('.type-btn').forEach(btn => btn.classList.remove('active'));
            event.target.closest('.type-btn').classList.add('active');
            document.getElementById('loginType').value = type;
            document.getElementById('submitBtn').disabled = false;
            
            if (type === 'admin') {
                document.getElementById('passwordField').style.display = 'block';
            } else {
                document.getElementById('passwordField').style.display = 'none';
            }
        }
    </script>
</body>
</html>
